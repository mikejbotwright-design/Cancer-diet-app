import React, { useState } from "react";
import {
  View,
  Text,
  ScrollView,
  TouchableOpacity,
  CheckBox,
  StyleSheet,
} from "react-native";

const mealPlan = [
  { day: 1, breakfast: "Oats + blueberries + flaxseed + turmeric", lunch: "Lentil veg soup + garlic", dinner: "Salmon + broccoli sprouts + quinoa" },
  { day: 2, breakfast: "Yogurt + berries + walnuts", lunch: "Chickpea salad + olive oil", dinner: "Tofu stir-fry + broccoli + garlic" },
  { day: 3, breakfast: "Green smoothie (spinach, berries, flax)", lunch: "Quinoa + roasted veg", dinner: "Chicken + kale + sweet potato" },
  { day: 4, breakfast: "Avocado toast + seeds", lunch: "Tomato bean soup", dinner: "Mackerel + cabbage + garlic" },
  { day: 5, breakfast: "Overnight oats + raspberries", lunch: "Hummus veggie wrap", dinner: "Lentil curry + turmeric + black pepper" },
  { day: 6, breakfast: "Kale apple smoothie", lunch: "Mixed bean salad", dinner: "Cod + asparagus + quinoa" },
  { day: 7, breakfast: "Yogurt + chia + blueberries", lunch: "Vegetable soup", dinner: "Chickpea spinach stew" },
  { day: 8, breakfast: "Oats + strawberries + flax", lunch: "Lentil salad", dinner: "Salmon + brussels sprouts" },
  { day: 9, breakfast: "Yogurt + berries + almonds", lunch: "Chickpea bowl", dinner: "Tofu + broccoli stir fry" },
  { day: 10, breakfast: "Green smoothie", lunch: "Quinoa veg bowl", dinner: "Chicken + kale" },
  { day: 11, breakfast: "Avocado toast", lunch: "Tomato soup", dinner: "Sardines + cabbage" },
  { day: 12, breakfast: "Overnight oats", lunch: "Veg wrap", dinner: "Lentil curry" },
  { day: 13, breakfast: "Berry smoothie", lunch: "Bean salad", dinner: "Cod + broccoli" },
  { day: 14, breakfast: "Yogurt + chia", lunch: "Veg soup", dinner: "Chickpea stew" }
];

export default function App() {
  const [day, setDay] = useState(1);
  const [checked, setChecked] = useState<Record<string, boolean>>({});
  const [water, setWater] = useState(0);

  const current = mealPlan.find((d) => d.day === day);

  const toggleCheck = (meal: string) => {
    setChecked({ ...checked, [day + meal]: !checked[day + meal] });
  };

  return (
    <ScrollView style={styles.container}>
      <Text style={styles.title}>Cancer-Fighting Diet App</Text>

      {/* Meal Plan Card */}
      <View style={styles.card}>
        <Text style={styles.cardTitle}>Day {current?.day}</Text>

        {(["breakfast", "lunch", "dinner"] as const).map((meal) => (
          <View key={meal} style={styles.mealItem}>
            <View style={styles.mealText}>
              <Text style={styles.mealLabel}>
                {meal.charAt(0).toUpperCase() + meal.slice(1)}
              </Text>
              <Text style={styles.mealDescription}>
                {current?.[meal]}
              </Text>
            </View>
            <CheckBox
              value={checked[day + meal] || false}
              onValueChange={() => toggleCheck(meal)}
            />
          </View>
        ))}
      </View>

      {/* Daily Boosters Card */}
      <View style={styles.card}>
        <Text style={styles.cardTitle}>Daily Boosters</Text>
        <Text style={styles.boosterItem}>• Green tea (2–3 cups)</Text>
        <Text style={styles.boosterItem}>• Turmeric + black pepper</Text>
        <Text style={styles.boosterItem}>• Garlic (crushed)</Text>
        <Text style={styles.boosterItem}>• Broccoli sprouts</Text>
        <Text style={styles.boosterItem}>• Extra virgin olive oil</Text>
      </View>

      {/* Hydration Tracker Card */}
      <View style={styles.card}>
        <Text style={styles.cardTitle}>Hydration Tracker</Text>
        <Text style={styles.waterText}>Glasses: {water}</Text>
        <TouchableOpacity
          style={styles.button}
          onPress={() => setWater(water + 1)}
        >
          <Text style={styles.buttonText}>+ Add Glass</Text>
        </TouchableOpacity>
      </View>

      {/* Day Navigation */}
      <View style={styles.dayNav}>
        {mealPlan.map((d) => (
          <TouchableOpacity
            key={d.day}
            style={[
              styles.dayButton,
              day === d.day ? styles.dayButtonActive : styles.dayButtonInactive,
            ]}
            onPress={() => setDay(d.day)}
          >
            <Text
              style={[
                styles.dayButtonText,
                day === d.day && styles.dayButtonTextActive,
              ]}
            >
              {d.day}
            </Text>
          </TouchableOpacity>
        ))}
      </View>

      {/* Footer Tip */}
      <Text style={styles.tip}>Tip: Aim for 30+ plant foods weekly 🌱</Text>
    </ScrollView>
  );
}

